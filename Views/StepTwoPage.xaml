<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CharacterBible.Views.StepTwoPage"
             Title="Krok 2: Rola w świecie">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <Label Text="Wybierz rolę:" FontAttributes="Bold" FontSize="22" />

            <Label Text="Wpisz własną rolę LUB wybierz z bazy poniżej:" FontSize="14" TextColor="Gray" />
            <Entry x:Name="CustomRoleEntry" Placeholder="Twoja własna profesja..." FontSize="16" />
            <Button Text="ZAPISZ" BackgroundColor="Beige" Clicked="OnCustomRoleSubmitted" FontFamily=" Gabriola" FontSize="20" />

            <BoxView HeightRequest="1" Color="Gray" Margin="0,10,0,10" />

            <VerticalStackLayout x:Name="RolesContainer" Spacing="8" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>