<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CharacterBible.Views.StepZeroPage"
             Title="Krok 0: Tożsamość"
             Background="Black" >

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="15">

            <Label Text="1. Wybierz płeć postaci:" FontAttributes="Bold" FontSize="18" />
            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <Button x:Name="BtnMale" Text="Mężczyzna" WidthRequest="120" FontFamily="Gabriola" FontSize="20" TextColor="black" BackgroundColor="Beige" Clicked="OnGenderSelected" />
                <Button x:Name="BtnFemale" Text="Kobieta" WidthRequest="120" FontFamily="Gabriola" FontSize="20" TextColor="black" BackgroundColor="Beige" Clicked="OnGenderSelected" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="Gray" Margin="0,5,0,5" />

            <Label Text="2. Dane identyfikacyjne:" FontAttributes="Bold" FontSize="18" />

            <Label Text="Imię:" FontSize="14" TextColor="Gray" />
            <Entry x:Name="FirstNameEntry" Placeholder="Wpisz lub wylosuj imię..." FontSize="16" />

            <Label Text="Nazwisko:" FontSize="14" TextColor="Gray" />
            <Entry x:Name="LastNameEntry" Placeholder="Wpisz lub wylosuj nazwisko..." FontSize="16" />

            <Label Text="Pseudonim (Opcjonalnie):" FontSize="14" TextColor="Gray" />
            <Entry x:Name="PseudoEntry" Placeholder="Wpisz lub wylosuj ksywę..." FontSize="16" />

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,10,0,0">
                <Button Text="Losuj Imię i Nazwisko" FontFamily="Gabriola" FontSize="20" TextColor="black" BackgroundColor="Beige" Clicked="OnRandomNameClicked" />
                <Button Text="Losuj Pseudonim" FontFamily="Gabriola" FontSize="20" TextColor="black" BackgroundColor="Beige" Clicked="OnRandomPseudoClicked" />
            </HorizontalStackLayout>

            <Button Text="Zatwierdź i przejdź dalej" FontFamily="Gabriola" FontSize="20" TextColor="black" BackgroundColor="Beige" Clicked="OnNextClicked" Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>