<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CharacterBible.Views.StepOnePage"
             Title="Krok 1: Energia">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20">

            <Label Text="Wybierz cechę:" FontAttributes="Bold" FontSize="36" FontFamily="Gabriola"/>

            <Label Text="Wpisz LUB wybierz:" FontSize="14" TextColor="Gray" FontFamily="Gabriola" />
            <Entry x:Name="CustomVibeEntry" Placeholder="Twoja własna cecha..." FontSize="16" FontFamily="Gabriola" />
            <Button Text="Zatwierdź" BackgroundColor="Beige" Clicked="OnCustomVibeSubmitted" FontFamily="Gabriola" />

            <BoxView HeightRequest="1" Color="Gray" Margin="0,10,0,10" />

            <VerticalStackLayout x:Name="VibesContainer" Spacing="8" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>